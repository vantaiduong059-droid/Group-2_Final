### Bước 7: Cập nhật engagement_scores thực tế

```sql
-- Course 25: Điểm tốt (đi học đầy đủ, tương tác nhiều)
-- Có mặt 3 buổi × 2đ = 6, Muộn 1 × 1đ = 1, Vắng có phép = 0 → attendance_points = 7
-- Tương tác: 1+2+1+1+2 = 7 interaction_points
UPDATE `engagement_scores` 
SET attendance_points = 7, interaction_points = 7, total_score = 70
WHERE course_id = 25 AND student_id = 242;

-- Course 27: Điểm kém (vắng 4 buổi, không tương tác)
-- Vắng 4 × 0đ = 0 attendance_points, interaction = 0
-- CPI = 0 → kích hoạt alert
UPDATE `engagement_scores` 
SET attendance_points = 0, interaction_points = 0, total_score = 10
WHERE course_id = 27 AND student_id = 242;

-- Course 30: Điểm trung bình
-- Present 2×2=4, Late 3×1=3, Absent 1×0=0 → 7, Tương tác: 1
UPDATE `engagement_scores` 
SET attendance_points = 7, interaction_points = 1, total_score = 45
WHERE course_id = 30 AND student_id = 242;
```

